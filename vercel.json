{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["uploads/**"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server/index.js" }
  ],
  "crons": [
    { "path": "/api/cron/sync", "schedule": "0 9 * * *" }
  ]
}
