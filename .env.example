PORT=3789

# Shopee Affiliate Open API (pedido em affiliate.shopee.com.br/open_api)
SHOPEE_APP_ID=
SHOPEE_SECRET=

# Supabase — NUNCA coloque a secret no HTML / frontend
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Alimentação automática da vitrine (mantém tudo no plano gratuito)
# AUTO_SYNC=1            -> liga/desliga (1/0) — padrão 0 (pausado)
# AUTO_SYNC_INTERVAL_MIN -> minutos entre cada lote (padrão 90)
# AUTO_SYNC_BATCH        -> quantas keywords por lote (padrão 5)
# AUTO_SYNC_LIMIT        -> itens por keyword (padrão 20)
# AUTO_PRUNE_DAYS        -> remove ofertas sem atualização há X dias (padrão 60, 0 desliga)
AUTO_SYNC=0
AUTO_SYNC_INTERVAL_MIN=90
AUTO_SYNC_BATCH=5
AUTO_SYNC_LIMIT=20
AUTO_PRUNE_DAYS=60
# Rating mínimo ao filtrar ofertas da API (padrão 4.0)
SYNC_MIN_RATING=4.0
# Delay entre páginas/keywords em buscas em lote (ms, padrão 350)
# SHOPEE_BATCH_GAP_MS=350
